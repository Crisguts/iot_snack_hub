# Flask Configuration
SECRET_KEY=your_super_secret_key_change_this_in_production

# Supabase Database
SUPABASE_URL=https://yourproject.supabase.co
SUPABASE_KEY=your_supabase_anon_key_here

# Email Configuration (Gmail)
EMAIL_LOGIN=your-email@gmail.com
EMAIL_APP_PASSWORD=your_gmail_app_password_16_chars
EMAIL_RECIPIENT=alert-recipient@gmail.com

# MQTT Configuration
MQTT_BROKER=localhost
MQTT_PORT=1883
MQTT_TOPICS=Frig1,Frig2
MQTT_AUTO_START=true

# Mock Mode (for development without Raspberry Pi GPIO hardware)
MOCK_MODE=True
